# This is Git's per-user configuration file.
[user]
	name = Archisman Mridha
	email = archismanmridha12345@gmail.com
	signingkey = 2B1FEBABE7FAFB3C

[commit]
	gpgsign = true

[push]
  autoSetupRemote = true

[gpg]
	program = /Users/archismanmridha/.nix-profile/bin/gpg

# Delta related configurations

[core]
    pager = delta
[interactive]
    diffFilter = delta --color-only
[delta]
    navigate = true # use n and N to move between diff sections
[merge]
    conflictstyle = diff3
[diff]
    colorMoved = default
