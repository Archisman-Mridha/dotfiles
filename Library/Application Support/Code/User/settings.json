{
  "window.commandCenter": false,
  "window.titleBarStyle": "custom",
  "workbench.fontAliasing": "antialiased",
  "workbench.iconTheme": "catppuccin-macchiato",
  "workbench.tree.renderIndentGuides": "always",
  "workbench.tree.indent": 12,
  "workbench.tree.enableStickyScroll": false,
  "workbench.tree.stickyScrollMaxItemCount": 1,
  "workbench.layoutControl.enabled": false,
  "workbench.colorCustomizations": {
    "editor.background": "#151515",
    "editorGutter.background": "#151515",
    "editorGroupHeader.tabsBackground": "#151515",
    "editorGroup.emptyBackground": "#151515",
    "sideBar.background": "#151515",
    "tree.indentGuidesStroke": "#686868",
    "activityBar.background": "#151515",
    "statusBar.background": "#151515",
    "titleBar.activeBackground": "#151515",
    "tab.inactiveBackground": "#151515",
    "tab.activeBackground": "#151515",
    "sideBar.border": "#303030"
  },

  "editor.formatOnSave": false,
  "editor.semanticHighlighting.enabled": true,
  "editor.cursorBlinking": "expand",
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.fontFamily": "Monaco for Powerline, Liga Liberation Mono",
  "editor.fontWeight": "400",
  "editor.fontLigatures": true,
  "editor.fontSize": 18,
  "editor.lineHeight": 1.5,
  "editor.renderLineHighlight": "none",
  "editor.renderWhitespace": "none",
  "editor.stickyScroll.enabled": false,
  "editor.inlineSuggest.suppressSuggestions": true,
  "editor.wordWrapColumn": 100,
  "editor.codeLens": false,
  "editor.stickyScroll.scrollWithEditor": false,
  "editor.tokenColorCustomizations": {
    "textMateRules": [
      {
        "scope": ["comment"],
        "settings": {
          "fontStyle": "italic"
        }
      }
    ]
  },
  "editor.semanticTokenColorCustomizations": {
    "enabled": true,
    "rules": {
      "*.mutable": {
        "underline": false
      }
    }
  },
  "editor.rulers": [100, 125],
  "editor.minimap.enabled": false,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.tabSize": 2,
  "editor.inlayHints.enabled": "off",

  "terminal.integrated.fontFamily": "Monaco for Powerline",
  "terminal.integrated.fontSize": 18,
  "terminal.integrated.fontWeight": "400",
  "terminal.integrated.lineHeight": 1.2,

  "explorer.compactFolders": false,
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,

  "breadcrumbs.enabled": false,
  "git.openRepositoryInParentFolders": "always",
  "security.promptForLocalFileProtocolHandling": false,

  "[rust]": {
    "editor.defaultFormatter": "rust-lang.rust-analyzer"
  },
  "go.formatTool": "gofmt",
  "go.toolsManagement.autoUpdate": true,
  "[go]": {
    "editor.defaultFormatter": "golang.go"
  },
  "gopls": {
    "ui.semanticTokens": true
  },
  "typescript.updateImportsOnFileMove.enabled": "always",
  "svelte.enable-ts-plugin": true,
  "solidity.telemetry": false,
  "json.schemaDownload.enable": true,
  "redhat.telemetry.enabled": true
}
